<?xml version="1.0" encoding="UTF-8"?>
<addon
  id="pvr.kofin"
  version="0.4.0"
  name="Kofin PVR for Jellyfin"
  provider-name="Kontell">
  <requires>@ADDON_DEPENDS@
    <import addon="inputstream.ffmpegdirect" minversion="20.0.0"/>
    <import addon="inputstream.adaptive" minversion="20.0.0"/>
  </requires>
  <extension
    point="kodi.pvrclient"
    library_@PLATFORM@="@LIBRARY_FILENAME@"/>
  <extension point="xbmc.service" library="resources/scripts/service.py" start="startup"/>
  <extension point="xbmc.addon.metadata">
    <platform>@PLATFORM@</platform>
    <license>GPL-2.0-or-later</license>
    <assets>
      <icon>icon.png</icon>
    </assets>
    <summary lang="en_GB">Kodi PVR client for Jellyfin Live TV</summary>
    <description lang="en_GB">Native Kodi PVR integration for Jellyfin Live TV. Provides live TV channels, EPG, recordings, and timers from a Jellyfin server with native Kodi UI integration.</description>
  </extension>
</addon>
