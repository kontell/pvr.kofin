msgctxt "Addon Summary"
msgid "Kodi PVR addon for Jellyfin Live TV."
msgstr "Doplněk PVR pro Kodi pro živou televizi Jellyfin."

msgctxt "Addon Description"
msgid "Native Kodi PVR integration for Jellyfin Live TV. Provides live TV channels, EPG, recordings, and timers from a Jellyfin server."
msgstr "Nativní integrace PVR v Kodi pro živou televizi Jellyfin. Poskytuje kanály živé televize, EPG, nahrávky a časovače ze serveru Jellyfin."

#: Transcoding category
msgctxt "#30620"
msgid "Transcoding"
msgstr "Překódování"

msgctxt "#30622"
msgid "Force remuxing"
msgstr "Vynutit remux"

msgctxt "#30623"
msgid "Force the Jellyfin server to remux all live TV streams into HLS instead of direct playing. Allows for stream sharing if enabled in Jellyfin tuner settings."
msgstr "Vynutí, aby server Jellyfin remuxoval všechny streamy živé televize do HLS místo přímého přehrávání. Umožňuje sdílení streamů, pokud je povoleno v nastavení tuneru Jellyfin."

msgctxt "#30624"
msgid "Preferred video codec"
msgstr "Preferovaný videokodek"

msgctxt "#30625"
msgid "The video codec to request when transcoding. AV1 will not be chosen by Jellyfin for encoding unless the source codec is also AV1 or the source codec is turned off for direct play."
msgstr "Videokodek požadovaný při překódování. Jellyfin nezvolí AV1 pro kódování, pokud zdrojový kodek není rovněž AV1 nebo pokud zdrojový kodek není vypnut pro přímé přehrávání."

msgctxt "#30626"
msgid "H264"
msgstr "H264"

msgctxt "#30627"
msgid "H265/HEVC"
msgstr "H265/HEVC"

msgctxt "#30628"
msgid "AV1"
msgstr "AV1"

msgctxt "#30629"
msgid "Preferred audio codec"
msgstr "Preferovaný zvukový kodek"

msgctxt "#30630"
msgid "The audio codec to request when transcoding."
msgstr "Zvukový kodek požadovaný při překódování."

msgctxt "#30631"
msgid "AAC"
msgstr "AAC"

msgctxt "#30632"
msgid "AC3"
msgstr "AC3"

msgctxt "#30633"
msgid "MP3"
msgstr "MP3"

msgctxt "#30634"
msgid "Maximum streaming bitrate"
msgstr "Maximální datový tok streamování"

msgctxt "#30635"
msgid "Any value other than unlimited disables direct play. If a stream is below the limit it will remux and if above it will transcode."
msgstr "Jakákoli hodnota kromě „neomezeno“ vypne přímé přehrávání. Pokud je stream pod limitem, bude remuxován, a pokud nad ním, bude překódován."

