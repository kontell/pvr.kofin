msgctxt "#30645"
msgid "30 Mbps"
msgstr "30 Mbps"

msgctxt "#30646"
msgid "40 Mbps"
msgstr "40 Mbps"

msgctxt "#30647"
msgid "60 Mbps"
msgstr "60 Mbps"

msgctxt "#30648"
msgid "80 Mbps"
msgstr "80 Mbps"

msgctxt "#30649"
msgid "100 Mbps"
msgstr "100 Mbps"

msgctxt "#30650"
