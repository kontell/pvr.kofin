msgctxt "Addon Summary"
msgid "Kodi PVR addon for Jellyfin Live TV."
msgstr "Kodi PVR-kiegészítő a Jellyfin élő TV-jéhez."

msgctxt "Addon Description"
msgid "Native Kodi PVR integration for Jellyfin Live TV. Provides live TV channels, EPG, recordings, and timers from a Jellyfin server."
msgstr "Natív Kodi PVR-integráció a Jellyfin élő TV-jéhez. Élő TV-csatornákat, EPG-t, felvételeket és időzítőket biztosít egy Jellyfin-kiszolgálóról."

#: Transcoding category
msgctxt "#30620"
msgid "Transcoding"
msgstr "Átkódolás"

msgctxt "#30622"
msgid "Force remuxing"
msgstr "Remuxolás kényszerítése"

msgctxt "#30623"
msgid "Force the Jellyfin server to remux all live TV streams into HLS instead of direct playing. Allows for stream sharing if enabled in Jellyfin tuner settings."
msgstr "Arra kényszeríti a Jellyfin-kiszolgálót, hogy az összes élő TV-adatfolyamot HLS-be remuxolja a közvetlen lejátszás helyett. Lehetővé teszi az adatfolyamok megosztását, ha engedélyezve van a Jellyfin tunerbeállításaiban."

msgctxt "#30624"
msgid "Preferred video codec"
msgstr "Előnyben részesített videokodek"

msgctxt "#30625"
msgid "The video codec to request when transcoding. AV1 will not be chosen by Jellyfin for encoding unless the source codec is also AV1 or the source codec is turned off for direct play."
msgstr "Az átkódoláskor kért videokodek. A Jellyfin nem választja az AV1-et kódoláshoz, hacsak a forráskodek is AV1, vagy a forráskodek le van tiltva a közvetlen lejátszáshoz."

msgctxt "#30626"
msgid "H264"
msgstr "H264"

msgctxt "#30627"
msgid "H265/HEVC"
msgstr "H265/HEVC"

msgctxt "#30628"
msgid "AV1"
msgstr "AV1"

msgctxt "#30629"
msgid "Preferred audio codec"
msgstr "Előnyben részesített hangkodek"

msgctxt "#30630"
msgid "The audio codec to request when transcoding."
msgstr "Az átkódoláskor kért hangkodek."

msgctxt "#30631"
msgid "AAC"
msgstr "AAC"

msgctxt "#30632"
msgid "AC3"
msgstr "AC3"

msgctxt "#30633"
msgid "MP3"
msgstr "MP3"

msgctxt "#30634"
msgid "Maximum streaming bitrate"
msgstr "Maximális streamelési bitráta"

msgctxt "#30635"
msgid "Any value other than unlimited disables direct play. If a stream is below the limit it will remux and if above it will transcode."
msgstr "A korlátlanon kívül bármely érték letiltja a közvetlen lejátszást. Ha egy adatfolyam a korlát alatt van, remuxolásra kerül, ha felette, akkor átkódolásra."

