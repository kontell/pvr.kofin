msgctxt "Addon Summary"
msgid "Kodi PVR addon for Jellyfin Live TV."
msgstr "Add-on PVR do Kodi para a TV ao vivo Jellyfin."

msgctxt "Addon Description"
msgid "Native Kodi PVR integration for Jellyfin Live TV. Provides live TV channels, EPG, recordings, and timers from a Jellyfin server."
msgstr "Integração PVR nativa do Kodi para a TV ao vivo Jellyfin. Fornece canais de TV ao vivo, EPG, gravações e temporizadores a partir de um servidor Jellyfin."

#: Transcoding category
msgctxt "#30620"
msgid "Transcoding"
msgstr "Transcodificação"

msgctxt "#30622"
msgid "Force remuxing"
msgstr "Forçar remux"

msgctxt "#30623"
msgid "Force the Jellyfin server to remux all live TV streams into HLS instead of direct playing. Allows for stream sharing if enabled in Jellyfin tuner settings."
msgstr "Força o servidor Jellyfin a fazer remux de todas as transmissões de TV ao vivo para HLS em vez de reproduzi-las diretamente. Permite o compartilhamento de transmissões se estiver ativado nas configurações do sintonizador do Jellyfin."

msgctxt "#30624"
msgid "Preferred video codec"
msgstr "Codec de vídeo preferido"

msgctxt "#30625"
msgid "The video codec to request when transcoding. AV1 will not be chosen by Jellyfin for encoding unless the source codec is also AV1 or the source codec is turned off for direct play."
msgstr "O codec de vídeo a solicitar durante a transcodificação. O AV1 não será escolhido pelo Jellyfin para codificação, a menos que o codec de origem também seja AV1 ou que o codec de origem esteja desativado para reprodução direta."

msgctxt "#30626"
msgid "H264"
msgstr "H264"

msgctxt "#30627"
msgid "H265/HEVC"
msgstr "H265/HEVC"

msgctxt "#30628"
msgid "AV1"
msgstr "AV1"

msgctxt "#30629"
msgid "Preferred audio codec"
msgstr "Codec de áudio preferido"

msgctxt "#30630"
msgid "The audio codec to request when transcoding."
msgstr "O codec de áudio a solicitar durante a transcodificação."

msgctxt "#30631"
msgid "AAC"
msgstr "AAC"

msgctxt "#30632"
msgid "AC3"
msgstr "AC3"

msgctxt "#30633"
msgid "MP3"
msgstr "MP3"

msgctxt "#30634"
msgid "Maximum streaming bitrate"
msgstr "Taxa de bits máxima de transmissão"

msgctxt "#30635"
msgid "Any value other than unlimited disables direct play. If a stream is below the limit it will remux and if above it will transcode."
msgstr "Qualquer valor diferente de ilimitado desativa a reprodução direta. Se uma transmissão estiver abaixo do limite, será feito remux; se estiver acima, será transcodificada."

