msgctxt "#30760"
msgid "Disabled"
msgstr "Dezactivat"

msgctxt "#30761"
msgid "Default"
msgstr "Implicit"

msgctxt "#30762"
msgid "Append"
msgstr "Adăugare"

msgctxt "#30763"
msgid "Shift (SIPTV)"
msgstr "Decalare (SIPTV)"

msgctxt "#30770"
msgid "Local path"
msgstr "Cale locală"

msgctxt "#30771"
msgid "Remote path (URL)"
msgstr "Cale la distanță (URL)"

#: Reference playlist (advanced category)
msgctxt "#30772"
msgid "Reference playlist"
msgstr "Listă de redare de referință"

msgctxt "#30773"
msgid "Use reference playlist"
msgstr "Utilizează o listă de redare de referință"

msgctxt "#30774"
msgid "Load a reference M3U playlist that decorates Jellyfin channels with channel groups, KodiProps (inputstream selection, headers), KofinProps (per-channel overrides) and catchup metadata. Channels are matched by name (case-insensitive)."
msgstr "Încarcă o listă de redare M3U de referință care îmbogățește canalele Jellyfin cu grupuri de canale, KodiProps (selectarea inputstream-ului, anteturi), KofinProps (suprascrieri per canal) și metadate de catchup. Canalele sunt asociate după nume (fără a ține cont de majuscule și minuscule)."

msgctxt "#30775"
msgid "Reference playlist location"
msgstr "Locația listei de redare de referință"

msgctxt "#30776"
msgid "Choose whether the reference playlist is stored locally or accessed via a URL."
msgstr "Alegeți dacă lista de redare de referință este stocată local sau accesată printr-un URL."

msgctxt "#30777"
msgid "Reference playlist file"
msgstr "Fișierul listei de redare de referință"

msgctxt "#30778"
msgid "Path to the reference M3U file on the local filesystem."
msgstr "Calea către fișierul M3U de referință din sistemul de fișiere local."

msgctxt "#30779"
msgid "Reference playlist URL"
msgstr "URL-ul listei de redare de referință"

msgctxt "#30780"
msgid "URL of the reference M3U playlist."
msgstr "URL-ul listei de redare M3U de referință."

#: Force-transcode codec toggles
msgctxt "#30781"
msgid "Direct play video codecs"
msgstr "Codecuri video pentru redare directă"

msgctxt "#30782"
msgid "Video codecs that can direct play or remux. Codecs not selected will be transcoded to the preferred video codec."
msgstr "Codecuri video care pot fi redate direct sau remultiplexate. Codecurile neselectate vor fi transcodate în codecul video preferat."

msgctxt "#30783"
msgid "Direct play audio codecs"
msgstr "Codecuri audio pentru redare directă"

msgctxt "#30784"
msgid "Audio codecs that can be copied through. Codecs not selected will be transcoded to the preferred audio codec."
msgstr "Codecuri audio care pot fi copiate fără recodare. Codecurile neselectate vor fi transcodate în codecul audio preferat."

msgctxt "#30796"
msgid "MPEG-2"
msgstr "MPEG-2"

msgctxt "#30797"
msgid "VP9"
msgstr "VP9"

msgctxt "#30798"
msgid "VC-1"
msgstr "VC-1"

msgctxt "#30799"
msgid "MP2"
msgstr "MP2"

msgctxt "#30800"
msgid "EAC3"
msgstr "EAC3"

msgctxt "#30801"
msgid "FLAC"
msgstr "FLAC"

msgctxt "#30805"
msgid "DTS"
msgstr "DTS"

msgctxt "#30806"
msgid "Force transcoding"
msgstr "Forțează transcodarea"

msgctxt "#30807"
msgid "Force the server to transcode to the preferred video codec instead of remuxing. The bitrate is capped at the source bitrate (or the maximum streaming bitrate, whichever is lower) to trigger re-encoding."
msgstr "Forțează serverul să transcodeze în codecul video preferat în loc să remultiplexeze. Rata de biți este limitată la cea a sursei (sau la rata de biți maximă pentru streaming, oricare este mai mică) pentru a declanșa recodarea."

msgctxt "#30808"
msgid "Force direct play"
msgstr "Forțează redarea directă"

msgctxt "#30809"
msgid "Force the server to direct play all streams without transcoding or remuxing. The device must be able to decode the source format natively. Does not apply to in-progress recordings. Can also be set per-channel via the kofin-force-direct-play M3U property."
msgstr "Forțează serverul să redea direct toate fluxurile, fără transcodare sau remultiplexare. Dispozitivul trebuie să poată decoda nativ formatul sursă. Nu se aplică înregistrărilor în curs. Poate fi setat și per canal prin proprietatea M3U kofin-force-direct-play."

msgctxt "#30802"
msgid "H264 10-bit"
msgstr "H264 10-bit"

msgctxt "#30803"
msgid "HEVC Range Extensions"
msgstr "HEVC Range Extensions"

msgctxt "#30791"
msgid "Maximum audio channels"
msgstr "Număr maxim de canale audio"

msgctxt "#30792"
msgid "Maximum number of audio channels allowed when transcoding. Streams with more channels will be downmixed. No effect on direct playback."
msgstr "Numărul maxim de canale audio permise la transcodare. Fluxurile cu mai multe canale vor fi reduse (downmix). Niciun efect asupra redării directe."

msgctxt "#30793"
msgid "Stereo (2)"
msgstr "Stereo (2)"

msgctxt "#30794"
msgid "Surround 5.1 (6)"
msgstr "Surround 5.1 (6)"

msgctxt "#30795"
msgid "Surround 7.1 (8)"
msgstr "Surround 7.1 (8)"

#: Allowed HDR types (allowedHdrTypes)
msgctxt "#30810"
msgid "Allowed HDR types"
msgstr "Tipuri HDR permise"

msgctxt "#30811"
msgid "HDR formats allowed to pass through to your display. Formats not selected are tone-mapped to SDR by the server. SDR is always allowed. No effect when Force direct play is on."
msgstr "Formate HDR permise să treacă către afișajul dvs. Formatele neselectate sunt convertite la SDR de către server prin mapare tonală. SDR este întotdeauna permis. Niciun efect când «Forțează redarea directă» este activat."

msgctxt "#30812"
msgid "HDR10"
msgstr "HDR10"

msgctxt "#30813"
msgid "HLG"
msgstr "HLG"

msgctxt "#30814"
msgid "HDR10+"
msgstr "HDR10+"

msgctxt "#30815"
msgid "Dolby Vision"
msgstr "Dolby Vision"

msgctxt "#30816"
msgid "Dolby Vision (HDR10 fallback)"
msgstr "Dolby Vision (rezervă HDR10)"

msgctxt "#30817"
msgid "Dolby Vision (HLG fallback)"
msgstr "Dolby Vision (rezervă HLG)"

msgctxt "#30818"
msgid "Dolby Vision (SDR fallback)"
msgstr "Dolby Vision (rezervă SDR)"

msgctxt "#30819"
msgid "Dolby Vision Profile 7 (EL)"
msgstr "Dolby Vision Profile 7 (EL)"

msgctxt "#30820"
msgid "Dolby Vision + HDR10+"
msgstr "Dolby Vision + HDR10+"

msgctxt "#30821"
msgid "Dolby Vision Profile 7 + HDR10+"
msgstr "Dolby Vision Profile 7 + HDR10+"

#: Maximum resolution (maxResolution)
msgctxt "#30822"
msgid "Maximum resolution"
msgstr "Rezoluție maximă"

msgctxt "#30823"
msgid "Caps video by width; higher-resolution sources are downscaled by the server. No effect when Force direct play is on."
msgstr "Limitează videoclipul după lățime; sursele cu rezoluție mai mare sunt reduse de server. Niciun efect când «Forțează redarea directă» este activat."

msgctxt "#30824"
msgid "480p"
msgstr "480p"

msgctxt "#30825"
msgid "720p"
msgstr "720p"

msgctxt "#30826"
msgid "1080p"
msgstr "1080p"

msgctxt "#30827"
msgid "1440p"
msgstr "1440p"

msgctxt "#30828"
msgid "2160p (4K)"
msgstr "2160p (4K)"

msgctxt "#30829"
msgid "Unlimited"
msgstr "Nelimitat"
