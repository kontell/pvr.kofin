msgid "480p"
msgstr "480p"

msgctxt "#30825"
msgid "720p"
msgstr "720p"

msgctxt "#30826"
msgid "1080p"
msgstr "1080p"

msgctxt "#30827"
msgid "1440p"
msgstr "1440p"

msgctxt "#30828"
msgid "2160p (4K)"
msgstr "2160p (4K)"

