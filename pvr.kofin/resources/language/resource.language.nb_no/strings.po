msgctxt "Addon Summary"
msgid "Kodi PVR addon for Jellyfin Live TV."
msgstr "Kodi-PVR-tillegg for Jellyfin live-TV."

msgctxt "Addon Description"
msgid "Native Kodi PVR integration for Jellyfin Live TV. Provides live TV channels, EPG, recordings, and timers from a Jellyfin server."
msgstr "Innebygd Kodi-PVR-integrasjon for Jellyfin live-TV. Gir live-TV-kanaler, EPG, opptak og tidsur fra en Jellyfin-server."

#: Transcoding category
msgctxt "#30620"
msgid "Transcoding"
msgstr "Transkoding"

msgctxt "#30622"
msgid "Force remuxing"
msgstr "Tving remuksing"

msgctxt "#30623"
msgid "Force the Jellyfin server to remux all live TV streams into HLS instead of direct playing. Allows for stream sharing if enabled in Jellyfin tuner settings."
msgstr "Tvinger Jellyfin-serveren til å remukse alle live-TV-strømmer til HLS i stedet for å direkteavspille dem. Tillater strømdeling hvis det er aktivert i Jellyfins tunerinnstillinger."

msgctxt "#30624"
msgid "Preferred video codec"
msgstr "Foretrukket videokodek"

msgctxt "#30625"
msgid "The video codec to request when transcoding. AV1 will not be chosen by Jellyfin for encoding unless the source codec is also AV1 or the source codec is turned off for direct play."
msgstr "Videokodeken som skal forespørres ved transkoding. AV1 velges ikke av Jellyfin for koding med mindre kildekodeken også er AV1, eller kildekodeken er deaktivert for direkteavspilling."

msgctxt "#30626"
msgid "H264"
msgstr "H264"

msgctxt "#30627"
msgid "H265/HEVC"
msgstr "H265/HEVC"

msgctxt "#30628"
msgid "AV1"
msgstr "AV1"

msgctxt "#30629"
msgid "Preferred audio codec"
msgstr "Foretrukket lydkodek"

msgctxt "#30630"
msgid "The audio codec to request when transcoding."
msgstr "Lydkodeken som skal forespørres ved transkoding."

msgctxt "#30631"
msgid "AAC"
msgstr "AAC"

msgctxt "#30632"
msgid "AC3"
msgstr "AC3"

msgctxt "#30633"
msgid "MP3"
msgstr "MP3"

msgctxt "#30634"
msgid "Maximum streaming bitrate"
msgstr "Maksimal strømmebitrate"

msgctxt "#30635"
msgid "Any value other than unlimited disables direct play. If a stream is below the limit it will remux and if above it will transcode."
msgstr "Enhver annen verdi enn ubegrenset deaktiverer direkteavspilling. Hvis en strøm er under grensen, remukses den, og hvis den er over, transkodes den."

