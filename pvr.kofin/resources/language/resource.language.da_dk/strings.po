msgctxt "Addon Summary"
msgid "Kodi PVR addon for Jellyfin Live TV."
msgstr "Kodi-PVR-tilføjelse til Jellyfin-live-tv."

msgctxt "Addon Description"
msgid "Native Kodi PVR integration for Jellyfin Live TV. Provides live TV channels, EPG, recordings, and timers from a Jellyfin server."
msgstr "Indbygget Kodi-PVR-integration til Jellyfin-live-tv. Leverer live-tv-kanaler, EPG, optagelser og timere fra en Jellyfin-server."

#: Transcoding category
msgctxt "#30620"
msgid "Transcoding"
msgstr "Transkodning"

msgctxt "#30622"
msgid "Force remuxing"
msgstr "Tving remuxning"

msgctxt "#30623"
msgid "Force the Jellyfin server to remux all live TV streams into HLS instead of direct playing. Allows for stream sharing if enabled in Jellyfin tuner settings."
msgstr "Tvinger Jellyfin-serveren til at remuxe alle live-tv-streams til HLS i stedet for at afspille dem direkte. Tillader deling af streams, hvis det er aktiveret i Jellyfins tunerindstillinger."

msgctxt "#30624"
msgid "Preferred video codec"
msgstr "Foretrukken videocodec"

msgctxt "#30625"
msgid "The video codec to request when transcoding. AV1 will not be chosen by Jellyfin for encoding unless the source codec is also AV1 or the source codec is turned off for direct play."
msgstr "Den videocodec, der anmodes om ved transkodning. AV1 vælges ikke af Jellyfin til kodning, medmindre kildecodecen også er AV1, eller kildecodecen er deaktiveret for direkte afspilning."

msgctxt "#30626"
msgid "H264"
msgstr "H264"

msgctxt "#30627"
msgid "H265/HEVC"
msgstr "H265/HEVC"

msgctxt "#30628"
msgid "AV1"
msgstr "AV1"

msgctxt "#30629"
msgid "Preferred audio codec"
msgstr "Foretrukken lydcodec"

msgctxt "#30630"
msgid "The audio codec to request when transcoding."
msgstr "Den lydcodec, der anmodes om ved transkodning."

msgctxt "#30631"
msgid "AAC"
msgstr "AAC"

msgctxt "#30632"
msgid "AC3"
msgstr "AC3"

msgctxt "#30633"
msgid "MP3"
msgstr "MP3"

msgctxt "#30634"
msgid "Maximum streaming bitrate"
msgstr "Maksimal streaming-bithastighed"

msgctxt "#30635"
msgid "Any value other than unlimited disables direct play. If a stream is below the limit it will remux and if above it will transcode."
msgstr "Enhver anden værdi end ubegrænset deaktiverer direkte afspilning. Hvis en stream er under grænsen, remuxes den, og hvis den er over, transkodes den."

