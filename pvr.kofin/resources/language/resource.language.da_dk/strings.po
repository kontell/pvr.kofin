msgctxt "#30760"
msgid "Disabled"
msgstr "Deaktiveret"

msgctxt "#30761"
msgid "Default"
msgstr "Standard"

msgctxt "#30762"
msgid "Append"
msgstr "Tilføj"

msgctxt "#30763"
msgid "Shift (SIPTV)"
msgstr "Forskydning (SIPTV)"

msgctxt "#30770"
msgid "Local path"
msgstr "Lokal sti"

msgctxt "#30771"
msgid "Remote path (URL)"
msgstr "Fjernsti (URL)"

#: Reference playlist (advanced category)
msgctxt "#30772"
msgid "Reference playlist"
msgstr "Referencespilleliste"

msgctxt "#30773"
msgid "Use reference playlist"
msgstr "Brug referencespilleliste"

msgctxt "#30774"
msgid "Load a reference M3U playlist that decorates Jellyfin channels with channel groups, KodiProps (inputstream selection, headers), KofinProps (per-channel overrides) and catchup metadata. Channels are matched by name (case-insensitive)."
msgstr "Indlæser en reference-M3U-spilleliste, der beriger Jellyfin-kanaler med kanalgrupper, KodiProps (valg af InputStream, headere), KofinProps (tilsidesættelser pr. kanal) og catchup-metadata. Kanaler matches efter navn (ikke versalfølsomt)."

msgctxt "#30775"
msgid "Reference playlist location"
msgstr "Placering af referencespilleliste"

msgctxt "#30776"
msgid "Choose whether the reference playlist is stored locally or accessed via a URL."
msgstr "Vælg, om referencespillelisten gemmes lokalt eller tilgås via en URL."

msgctxt "#30777"
msgid "Reference playlist file"
msgstr "Referencespillelistefil"

msgctxt "#30778"
msgid "Path to the reference M3U file on the local filesystem."
msgstr "Sti til reference-M3U-filen i det lokale filsystem."

msgctxt "#30779"
msgid "Reference playlist URL"
msgstr "URL til referencespilleliste"

msgctxt "#30780"
msgid "URL of the reference M3U playlist."
msgstr "URL til reference-M3U-spillelisten."

#: Force-transcode codec toggles
msgctxt "#30781"
msgid "Direct play video codecs"
msgstr "Videocodecs til direkte afspilning"

msgctxt "#30782"
msgid "Video codecs that can direct play or remux. Codecs not selected will be transcoded to the preferred video codec."
msgstr "Videocodecs, der kan afspilles direkte eller remuxes. Codecs, der ikke vælges, transkodes til den foretrukne videocodec."

msgctxt "#30783"
msgid "Direct play audio codecs"
msgstr "Lydcodecs til direkte afspilning"

msgctxt "#30784"
msgid "Audio codecs that can be copied through. Codecs not selected will be transcoded to the preferred audio codec."
msgstr "Lydcodecs, der kan kopieres uændret igennem. Codecs, der ikke vælges, transkodes til den foretrukne lydcodec."

msgctxt "#30796"
msgid "MPEG-2"
msgstr "MPEG-2"

msgctxt "#30797"
msgid "VP9"
msgstr "VP9"

msgctxt "#30798"
msgid "VC-1"
msgstr "VC-1"

msgctxt "#30799"
msgid "MP2"
msgstr "MP2"

msgctxt "#30800"
msgid "EAC3"
msgstr "EAC3"

msgctxt "#30801"
msgid "FLAC"
msgstr "FLAC"

msgctxt "#30805"
msgid "DTS"
msgstr "DTS"

msgctxt "#30806"
msgid "Force transcoding"
msgstr "Tving transkodning"

msgctxt "#30807"
msgid "Force the server to transcode to the preferred video codec instead of remuxing. The bitrate is capped at the source bitrate (or the maximum streaming bitrate, whichever is lower) to trigger re-encoding."
msgstr "Tvinger serveren til at transkode til den foretrukne videocodec i stedet for at remuxe. Bithastigheden begrænses til kildens bithastighed (eller den maksimale streaming-bithastighed, alt efter hvad der er lavest) for at udløse omkodning."

msgctxt "#30808"
msgid "Force direct play"
msgstr "Tving direkte afspilning"

msgctxt "#30809"
msgid "Force the server to direct play all streams without transcoding or remuxing. The device must be able to decode the source format natively. Does not apply to in-progress recordings. Can also be set per-channel via the kofin-force-direct-play M3U property."
msgstr "Tvinger serveren til at afspille alle streams direkte uden transkodning eller remuxning. Enheden skal kunne afkode kildeformatet internt. Gælder ikke for igangværende optagelser. Kan også angives pr. kanal via M3U-egenskaben kofin-force-direct-play."

msgctxt "#30802"
msgid "H264 10-bit"
msgstr "H264 10-bit"

msgctxt "#30803"
msgid "HEVC Range Extensions"
msgstr "HEVC Range Extensions"

msgctxt "#30791"
msgid "Maximum audio channels"
msgstr "Maksimalt antal lydkanaler"

msgctxt "#30792"
msgid "Maximum number of audio channels allowed when transcoding. Streams with more channels will be downmixed. No effect on direct playback."
msgstr "Maksimalt antal lydkanaler, der er tilladt ved transkodning. Streams med flere kanaler nedmixes. Ingen effekt på direkte afspilning."

msgctxt "#30793"
msgid "Stereo (2)"
msgstr "Stereo (2)"

msgctxt "#30794"
msgid "Surround 5.1 (6)"
msgstr "Surround 5.1 (6)"

msgctxt "#30795"
msgid "Surround 7.1 (8)"
msgstr "Surround 7.1 (8)"

#: Allowed HDR types (allowedHdrTypes)
msgctxt "#30810"
msgid "Allowed HDR types"
msgstr "Tilladte HDR-typer"

msgctxt "#30811"
msgid "HDR formats allowed to pass through to your display. Formats not selected are tone-mapped to SDR by the server. SDR is always allowed. No effect when Force direct play is on."
msgstr "HDR-formater, der må sendes videre til din skærm. Formater, der ikke vælges, tonemappes til SDR af serveren. SDR er altid tilladt. Ingen effekt, når Tving direkte afspilning er slået til."

msgctxt "#30812"
msgid "HDR10"
msgstr "HDR10"

msgctxt "#30813"
msgid "HLG"
msgstr "HLG"

msgctxt "#30814"
msgid "HDR10+"
msgstr "HDR10+"

msgctxt "#30815"
msgid "Dolby Vision"
msgstr "Dolby Vision"

msgctxt "#30816"
msgid "Dolby Vision (HDR10 fallback)"
msgstr "Dolby Vision (HDR10-reserve)"

msgctxt "#30817"
msgid "Dolby Vision (HLG fallback)"
msgstr "Dolby Vision (HLG-reserve)"

msgctxt "#30818"
msgid "Dolby Vision (SDR fallback)"
msgstr "Dolby Vision (SDR-reserve)"

msgctxt "#30819"
msgid "Dolby Vision Profile 7 (EL)"
msgstr "Dolby Vision Profile 7 (EL)"

msgctxt "#30820"
msgid "Dolby Vision + HDR10+"
msgstr "Dolby Vision + HDR10+"

msgctxt "#30821"
msgid "Dolby Vision Profile 7 + HDR10+"
msgstr "Dolby Vision Profile 7 + HDR10+"

#: Maximum resolution (maxResolution)
msgctxt "#30822"
msgid "Maximum resolution"
msgstr "Maksimal opløsning"

msgctxt "#30823"
msgid "Caps video by width; higher-resolution sources are downscaled by the server. No effect when Force direct play is on."
msgstr "Begrænser videoen efter bredde; kilder med højere opløsning nedskaleres af serveren. Ingen effekt, når Tving direkte afspilning er slået til."

msgctxt "#30824"
msgid "480p"
msgstr "480p"

msgctxt "#30825"
msgid "720p"
msgstr "720p"

msgctxt "#30826"
msgid "1080p"
msgstr "1080p"

msgctxt "#30827"
msgid "1440p"
msgstr "1440p"

msgctxt "#30828"
msgid "2160p (4K)"
msgstr "2160p (4K)"

msgctxt "#30829"
msgid "Unlimited"
msgstr "Ubegrænset"
