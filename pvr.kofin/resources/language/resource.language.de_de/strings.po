msgctxt "Addon Summary"
msgid "Kodi PVR addon for Jellyfin Live TV."
msgstr "Kodi-PVR-Add-on für Jellyfin-Live-TV."

msgctxt "Addon Description"
msgid "Native Kodi PVR integration for Jellyfin Live TV. Provides live TV channels, EPG, recordings, and timers from a Jellyfin server."
msgstr "Native Kodi-PVR-Integration für Jellyfin-Live-TV. Bietet Live-TV-Kanäle, EPG, Aufnahmen und Timer von einem Jellyfin-Server."

#: Transcoding category
msgctxt "#30620"
msgid "Transcoding"
msgstr "Transkodierung"

msgctxt "#30622"
msgid "Force remuxing"
msgstr "Remuxing erzwingen"

msgctxt "#30623"
msgid "Force the Jellyfin server to remux all live TV streams into HLS instead of direct playing. Allows for stream sharing if enabled in Jellyfin tuner settings."
msgstr "Zwingt den Jellyfin-Server, alle Live-TV-Streams in HLS zu remuxen, anstatt sie direkt wiederzugeben. Ermöglicht die Stream-Freigabe, wenn sie in den Jellyfin-Tuner-Einstellungen aktiviert ist."

msgctxt "#30624"
msgid "Preferred video codec"
msgstr "Bevorzugter Video-Codec"

msgctxt "#30625"
msgid "The video codec to request when transcoding. AV1 will not be chosen by Jellyfin for encoding unless the source codec is also AV1 or the source codec is turned off for direct play."
msgstr "Der beim Transkodieren angeforderte Video-Codec. AV1 wird von Jellyfin nur dann zum Kodieren gewählt, wenn der Quell-Codec ebenfalls AV1 ist oder der Quell-Codec für die Direktwiedergabe deaktiviert ist."

msgctxt "#30626"
msgid "H264"
msgstr "H264"

msgctxt "#30627"
msgid "H265/HEVC"
msgstr "H265/HEVC"

msgctxt "#30628"
msgid "AV1"
msgstr "AV1"

msgctxt "#30629"
msgid "Preferred audio codec"
msgstr "Bevorzugter Audio-Codec"

msgctxt "#30630"
msgid "The audio codec to request when transcoding."
msgstr "Der beim Transkodieren angeforderte Audio-Codec."

msgctxt "#30631"
msgid "AAC"
msgstr "AAC"

msgctxt "#30632"
msgid "AC3"
msgstr "AC3"

msgctxt "#30633"
msgid "MP3"
msgstr "MP3"

msgctxt "#30634"
msgid "Maximum streaming bitrate"
msgstr "Maximale Streaming-Bitrate"

msgctxt "#30635"
msgid "Any value other than unlimited disables direct play. If a stream is below the limit it will remux and if above it will transcode."
msgstr "Jeder Wert außer „Unbegrenzt“ deaktiviert die Direktwiedergabe. Liegt ein Stream unter dem Limit, wird er remuxt; liegt er darüber, wird er transkodiert."

