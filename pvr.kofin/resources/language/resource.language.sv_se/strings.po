msgctxt "Addon Summary"
msgid "Kodi PVR addon for Jellyfin Live TV."
msgstr "Kodi-PVR-tillägg för Jellyfin live-TV."

msgctxt "Addon Description"
msgid "Native Kodi PVR integration for Jellyfin Live TV. Provides live TV channels, EPG, recordings, and timers from a Jellyfin server."
msgstr "Inbyggd Kodi-PVR-integration för Jellyfin live-TV. Tillhandahåller live-TV-kanaler, EPG, inspelningar och timers från en Jellyfin-server."

#: Transcoding category
msgctxt "#30620"
msgid "Transcoding"
msgstr "Omkodning"

msgctxt "#30622"
msgid "Force remuxing"
msgstr "Tvinga remuxning"

msgctxt "#30623"
msgid "Force the Jellyfin server to remux all live TV streams into HLS instead of direct playing. Allows for stream sharing if enabled in Jellyfin tuner settings."
msgstr "Tvingar Jellyfin-servern att remuxa alla live-TV-strömmar till HLS i stället för att direktuppspela dem. Tillåter strömdelning om det är aktiverat i Jellyfins tunerinställningar."

msgctxt "#30624"
msgid "Preferred video codec"
msgstr "Föredragen videocodec"

msgctxt "#30625"
msgid "The video codec to request when transcoding. AV1 will not be chosen by Jellyfin for encoding unless the source codec is also AV1 or the source codec is turned off for direct play."
msgstr "Videocodecen som ska begäras vid omkodning. AV1 väljs inte av Jellyfin för kodning om inte källcodecen också är AV1 eller om källcodecen är inaktiverad för direktuppspelning."

msgctxt "#30626"
msgid "H264"
msgstr "H264"

msgctxt "#30627"
msgid "H265/HEVC"
msgstr "H265/HEVC"

msgctxt "#30628"
msgid "AV1"
msgstr "AV1"

msgctxt "#30629"
msgid "Preferred audio codec"
msgstr "Föredragen ljudcodec"

msgctxt "#30630"
msgid "The audio codec to request when transcoding."
msgstr "Ljudcodecen som ska begäras vid omkodning."

msgctxt "#30631"
msgid "AAC"
msgstr "AAC"

msgctxt "#30632"
msgid "AC3"
msgstr "AC3"

msgctxt "#30633"
msgid "MP3"
msgstr "MP3"

msgctxt "#30634"
msgid "Maximum streaming bitrate"
msgstr "Maximal strömningsbithastighet"

msgctxt "#30635"
msgid "Any value other than unlimited disables direct play. If a stream is below the limit it will remux and if above it will transcode."
msgstr "Alla värden utom obegränsat inaktiverar direktuppspelning. Om en ström är under gränsen remuxas den, och om den är över omkodas den."

