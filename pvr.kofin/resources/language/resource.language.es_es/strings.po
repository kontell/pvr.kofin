msgctxt "Addon Summary"
msgid "Kodi PVR addon for Jellyfin Live TV."
msgstr "Complemento PVR de Kodi para la TV en directo de Jellyfin."

msgctxt "Addon Description"
msgid "Native Kodi PVR integration for Jellyfin Live TV. Provides live TV channels, EPG, recordings, and timers from a Jellyfin server."
msgstr "Integración PVR nativa de Kodi para la TV en directo de Jellyfin. Proporciona canales de TV en directo, EPG, grabaciones y temporizadores desde un servidor Jellyfin."

#: Transcoding category
msgctxt "#30620"
msgid "Transcoding"
msgstr "Transcodificación"

msgctxt "#30622"
msgid "Force remuxing"
msgstr "Forzar remuxado"

msgctxt "#30623"
msgid "Force the Jellyfin server to remux all live TV streams into HLS instead of direct playing. Allows for stream sharing if enabled in Jellyfin tuner settings."
msgstr "Fuerza al servidor Jellyfin a remuxar todos los flujos de TV en directo a HLS en lugar de reproducirlos directamente. Permite compartir flujos si está habilitado en los ajustes del sintonizador de Jellyfin."

msgctxt "#30624"
msgid "Preferred video codec"
msgstr "Códec de vídeo preferido"

msgctxt "#30625"
msgid "The video codec to request when transcoding. AV1 will not be chosen by Jellyfin for encoding unless the source codec is also AV1 or the source codec is turned off for direct play."
msgstr "El códec de vídeo que se solicitará al transcodificar. Jellyfin no elegirá AV1 para la codificación a menos que el códec de origen también sea AV1 o que el códec de origen esté desactivado para la reproducción directa."

msgctxt "#30626"
msgid "H264"
msgstr "H264"

msgctxt "#30627"
msgid "H265/HEVC"
msgstr "H265/HEVC"

msgctxt "#30628"
msgid "AV1"
msgstr "AV1"

msgctxt "#30629"
msgid "Preferred audio codec"
msgstr "Códec de audio preferido"

msgctxt "#30630"
msgid "The audio codec to request when transcoding."
msgstr "El códec de audio que se solicitará al transcodificar."

msgctxt "#30631"
msgid "AAC"
msgstr "AAC"

msgctxt "#30632"
msgid "AC3"
msgstr "AC3"

msgctxt "#30633"
msgid "MP3"
msgstr "MP3"

msgctxt "#30634"
msgid "Maximum streaming bitrate"
msgstr "Tasa de bits máxima de transmisión"

msgctxt "#30635"
msgid "Any value other than unlimited disables direct play. If a stream is below the limit it will remux and if above it will transcode."
msgstr "Cualquier valor distinto de ilimitado desactiva la reproducción directa. Si un flujo está por debajo del límite se remuxará, y si está por encima se transcodificará."

