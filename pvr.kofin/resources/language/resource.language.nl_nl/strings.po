msgctxt "Addon Summary"
msgid "Kodi PVR addon for Jellyfin Live TV."
msgstr "Kodi-PVR-add-on voor Jellyfin live-tv."

msgctxt "Addon Description"
msgid "Native Kodi PVR integration for Jellyfin Live TV. Provides live TV channels, EPG, recordings, and timers from a Jellyfin server."
msgstr "Native Kodi-PVR-integratie voor Jellyfin live-tv. Biedt live-tv-kanalen, EPG, opnamen en timers van een Jellyfin-server."

#: Transcoding category
msgctxt "#30620"
msgid "Transcoding"
msgstr "Transcoderen"

msgctxt "#30622"
msgid "Force remuxing"
msgstr "Remuxen forceren"

msgctxt "#30623"
msgid "Force the Jellyfin server to remux all live TV streams into HLS instead of direct playing. Allows for stream sharing if enabled in Jellyfin tuner settings."
msgstr "Dwingt de Jellyfin-server om alle live-tv-streams te remuxen naar HLS in plaats van ze direct af te spelen. Maakt het delen van streams mogelijk als dit is ingeschakeld in de Jellyfin-tunerinstellingen."

msgctxt "#30624"
msgid "Preferred video codec"
msgstr "Voorkeurscodec voor video"

msgctxt "#30625"
msgid "The video codec to request when transcoding. AV1 will not be chosen by Jellyfin for encoding unless the source codec is also AV1 or the source codec is turned off for direct play."
msgstr "De videocodec die bij het transcoderen wordt aangevraagd. AV1 wordt door Jellyfin niet voor het coderen gekozen, tenzij de broncodec ook AV1 is of de broncodec is uitgeschakeld voor direct afspelen."

msgctxt "#30626"
msgid "H264"
msgstr "H264"

msgctxt "#30627"
msgid "H265/HEVC"
msgstr "H265/HEVC"

msgctxt "#30628"
msgid "AV1"
msgstr "AV1"

msgctxt "#30629"
msgid "Preferred audio codec"
msgstr "Voorkeurscodec voor audio"

msgctxt "#30630"
msgid "The audio codec to request when transcoding."
msgstr "De audiocodec die bij het transcoderen wordt aangevraagd."

msgctxt "#30631"
msgid "AAC"
msgstr "AAC"

msgctxt "#30632"
msgid "AC3"
msgstr "AC3"

msgctxt "#30633"
msgid "MP3"
msgstr "MP3"

msgctxt "#30634"
msgid "Maximum streaming bitrate"
msgstr "Maximale streamingbitrate"

msgctxt "#30635"
msgid "Any value other than unlimited disables direct play. If a stream is below the limit it will remux and if above it will transcode."
msgstr "Elke andere waarde dan onbeperkt schakelt direct afspelen uit. Als een stream onder de limiet zit, wordt deze geremuxt; zit deze erboven, dan wordt deze getranscodeerd."

