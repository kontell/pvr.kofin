msgctxt "#30760"
msgid "Disabled"
msgstr "Disabilitato"

msgctxt "#30761"
msgid "Default"
msgstr "Predefinito"

msgctxt "#30762"
msgid "Append"
msgstr "Aggiungi"

msgctxt "#30763"
msgid "Shift (SIPTV)"
msgstr "Spostamento (SIPTV)"

msgctxt "#30770"
msgid "Local path"
msgstr "Percorso locale"

msgctxt "#30771"
msgid "Remote path (URL)"
msgstr "Percorso remoto (URL)"

#: Reference playlist (advanced category)
msgctxt "#30772"
msgid "Reference playlist"
msgstr "Playlist di riferimento"

msgctxt "#30773"
msgid "Use reference playlist"
msgstr "Usa una playlist di riferimento"

msgctxt "#30774"
msgid "Load a reference M3U playlist that decorates Jellyfin channels with channel groups, KodiProps (inputstream selection, headers), KofinProps (per-channel overrides) and catchup metadata. Channels are matched by name (case-insensitive)."
msgstr "Carica una playlist M3U di riferimento che arricchisce i canali Jellyfin con gruppi di canali, KodiProps (selezione dell'inputstream, intestazioni), KofinProps (override per canale) e metadati di catchup. I canali vengono associati per nome (senza distinzione tra maiuscole e minuscole)."

msgctxt "#30775"
msgid "Reference playlist location"
msgstr "Posizione della playlist di riferimento"

msgctxt "#30776"
msgid "Choose whether the reference playlist is stored locally or accessed via a URL."
msgstr "Scegli se la playlist di riferimento è memorizzata localmente o accessibile tramite un URL."

msgctxt "#30777"
msgid "Reference playlist file"
msgstr "File della playlist di riferimento"

msgctxt "#30778"
msgid "Path to the reference M3U file on the local filesystem."
msgstr "Percorso del file M3U di riferimento sul file system locale."

msgctxt "#30779"
msgid "Reference playlist URL"
msgstr "URL della playlist di riferimento"

msgctxt "#30780"
msgid "URL of the reference M3U playlist."
msgstr "URL della playlist M3U di riferimento."

#: Force-transcode codec toggles
msgctxt "#30781"
msgid "Direct play video codecs"
msgstr "Codec video per riproduzione diretta"

msgctxt "#30782"
msgid "Video codecs that can direct play or remux. Codecs not selected will be transcoded to the preferred video codec."
msgstr "Codec video che possono essere riprodotti direttamente o rimuxati. I codec non selezionati verranno transcodificati nel codec video preferito."

msgctxt "#30783"
msgid "Direct play audio codecs"
msgstr "Codec audio per riproduzione diretta"

msgctxt "#30784"
msgid "Audio codecs that can be copied through. Codecs not selected will be transcoded to the preferred audio codec."
msgstr "Codec audio che possono essere copiati senza ricodifica. I codec non selezionati verranno transcodificati nel codec audio preferito."

msgctxt "#30796"
msgid "MPEG-2"
msgstr "MPEG-2"

msgctxt "#30797"
msgid "VP9"
msgstr "VP9"

msgctxt "#30798"
msgid "VC-1"
msgstr "VC-1"

msgctxt "#30799"
msgid "MP2"
msgstr "MP2"

msgctxt "#30800"
msgid "EAC3"
msgstr "EAC3"

msgctxt "#30801"
msgid "FLAC"
msgstr "FLAC"

msgctxt "#30805"
msgid "DTS"
msgstr "DTS"

msgctxt "#30806"
msgid "Force transcoding"
msgstr "Forza la transcodifica"

msgctxt "#30807"
msgid "Force the server to transcode to the preferred video codec instead of remuxing. The bitrate is capped at the source bitrate (or the maximum streaming bitrate, whichever is lower) to trigger re-encoding."
msgstr "Forza il server a transcodificare nel codec video preferito anziché effettuare il remux. Il bitrate viene limitato a quello di origine (o al bitrate massimo di streaming, se inferiore) per attivare la ricodifica."

msgctxt "#30808"
msgid "Force direct play"
msgstr "Forza la riproduzione diretta"

msgctxt "#30809"
msgid "Force the server to direct play all streams without transcoding or remuxing. The device must be able to decode the source format natively. Does not apply to in-progress recordings. Can also be set per-channel via the kofin-force-direct-play M3U property."
msgstr "Forza il server a riprodurre direttamente tutti i flussi, senza transcodifica né remux. Il dispositivo deve essere in grado di decodificare nativamente il formato di origine. Non si applica alle registrazioni in corso. Può essere impostato anche per singolo canale tramite la proprietà M3U kofin-force-direct-play."

msgctxt "#30802"
msgid "H264 10-bit"
msgstr "H264 10-bit"

msgctxt "#30803"
msgid "HEVC Range Extensions"
msgstr "HEVC Range Extensions"

msgctxt "#30791"
msgid "Maximum audio channels"
msgstr "Numero massimo di canali audio"

msgctxt "#30792"
msgid "Maximum number of audio channels allowed when transcoding. Streams with more channels will be downmixed. No effect on direct playback."
msgstr "Numero massimo di canali audio consentiti durante la transcodifica. I flussi con più canali verranno ridotti (downmix). Nessun effetto sulla riproduzione diretta."

msgctxt "#30793"
msgid "Stereo (2)"
msgstr "Stereo (2)"

msgctxt "#30794"
msgid "Surround 5.1 (6)"
msgstr "Surround 5.1 (6)"

msgctxt "#30795"
msgid "Surround 7.1 (8)"
msgstr "Surround 7.1 (8)"

#: Allowed HDR types (allowedHdrTypes)
msgctxt "#30810"
msgid "Allowed HDR types"
msgstr "Tipi di HDR consentiti"

msgctxt "#30811"
msgid "HDR formats allowed to pass through to your display. Formats not selected are tone-mapped to SDR by the server. SDR is always allowed. No effect when Force direct play is on."
msgstr "Formati HDR che possono essere trasmessi al tuo schermo. I formati non selezionati vengono convertiti in SDR dal server tramite tone mapping. L'SDR è sempre consentito. Nessun effetto quando «Forza la riproduzione diretta» è attivo."

msgctxt "#30812"
msgid "HDR10"
msgstr "HDR10"

msgctxt "#30813"
msgid "HLG"
msgstr "HLG"

msgctxt "#30814"
msgid "HDR10+"
msgstr "HDR10+"

msgctxt "#30815"
msgid "Dolby Vision"
msgstr "Dolby Vision"

msgctxt "#30816"
msgid "Dolby Vision (HDR10 fallback)"
msgstr "Dolby Vision (fallback HDR10)"

msgctxt "#30817"
msgid "Dolby Vision (HLG fallback)"
msgstr "Dolby Vision (fallback HLG)"

msgctxt "#30818"
msgid "Dolby Vision (SDR fallback)"
msgstr "Dolby Vision (fallback SDR)"

msgctxt "#30819"
msgid "Dolby Vision Profile 7 (EL)"
msgstr "Dolby Vision Profile 7 (EL)"

msgctxt "#30820"
msgid "Dolby Vision + HDR10+"
msgstr "Dolby Vision + HDR10+"

msgctxt "#30821"
msgid "Dolby Vision Profile 7 + HDR10+"
msgstr "Dolby Vision Profile 7 + HDR10+"

#: Maximum resolution (maxResolution)
msgctxt "#30822"
msgid "Maximum resolution"
msgstr "Risoluzione massima"

msgctxt "#30823"
msgid "Caps video by width; higher-resolution sources are downscaled by the server. No effect when Force direct play is on."
msgstr "Limita il video in base alla larghezza; le sorgenti a risoluzione più elevata vengono ridimensionate dal server. Nessun effetto quando «Forza la riproduzione diretta» è attivo."

msgctxt "#30824"
msgid "480p"
msgstr "480p"

msgctxt "#30825"
msgid "720p"
msgstr "720p"

msgctxt "#30826"
msgid "1080p"
msgstr "1080p"

msgctxt "#30827"
msgid "1440p"
msgstr "1440p"

msgctxt "#30828"
msgid "2160p (4K)"
msgstr "2160p (4K)"

msgctxt "#30829"
msgid "Unlimited"
msgstr "Illimitato"

#: Notification when an in-progress recording stops before its scheduled end
msgctxt "#30830"
msgid "Recording stopped early"
msgstr "Registrazione interrotta in anticipo"

msgctxt "#30831"
msgid "Timer/recording poll interval"
msgstr "Intervallo di interrogazione timer/registrazioni"

msgctxt "#30832"
msgid "Seconds between polls of the Jellyfin server for timer and recording changes (recordings scheduled or finished elsewhere, EPG recording indicators, widgets). Clamped between 15 and 3600."
msgstr "Secondi tra le interrogazioni al server Jellyfin per rilevare modifiche a timer e registrazioni (registrazioni programmate o completate altrove, indicatori di registrazione nell'EPG, widget). Limitato tra 15 e 3600."
