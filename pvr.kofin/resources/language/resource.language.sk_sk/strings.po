msgctxt "Addon Summary"
msgid "Kodi PVR addon for Jellyfin Live TV."
msgstr "Doplnok PVR pre Kodi pre živú televíziu Jellyfin."

msgctxt "Addon Description"
msgid "Native Kodi PVR integration for Jellyfin Live TV. Provides live TV channels, EPG, recordings, and timers from a Jellyfin server."
msgstr "Natívna integrácia PVR v Kodi pre živú televíziu Jellyfin. Poskytuje kanály živej televízie, EPG, nahrávky a časovače zo servera Jellyfin."

#: Transcoding category
msgctxt "#30620"
msgid "Transcoding"
msgstr "Prekódovanie"

msgctxt "#30622"
msgid "Force remuxing"
msgstr "Vynútiť remux"

msgctxt "#30623"
msgid "Force the Jellyfin server to remux all live TV streams into HLS instead of direct playing. Allows for stream sharing if enabled in Jellyfin tuner settings."
msgstr "Vynúti, aby server Jellyfin remuxoval všetky streamy živej televízie do HLS namiesto priameho prehrávania. Umožňuje zdieľanie streamov, ak je povolené v nastaveniach tunera Jellyfin."

msgctxt "#30624"
msgid "Preferred video codec"
msgstr "Preferovaný videokodek"

msgctxt "#30625"
msgid "The video codec to request when transcoding. AV1 will not be chosen by Jellyfin for encoding unless the source codec is also AV1 or the source codec is turned off for direct play."
msgstr "Videokodek požadovaný pri prekódovaní. Jellyfin nezvolí AV1 na kódovanie, pokiaľ zdrojový kodek nie je tiež AV1 alebo pokiaľ zdrojový kodek nie je vypnutý pre priame prehrávanie."

msgctxt "#30626"
msgid "H264"
msgstr "H264"

msgctxt "#30627"
msgid "H265/HEVC"
msgstr "H265/HEVC"

msgctxt "#30628"
msgid "AV1"
msgstr "AV1"

msgctxt "#30629"
msgid "Preferred audio codec"
msgstr "Preferovaný zvukový kodek"

msgctxt "#30630"
msgid "The audio codec to request when transcoding."
msgstr "Zvukový kodek požadovaný pri prekódovaní."

msgctxt "#30631"
msgid "AAC"
msgstr "AAC"

msgctxt "#30632"
msgid "AC3"
msgstr "AC3"

msgctxt "#30633"
msgid "MP3"
msgstr "MP3"

msgctxt "#30634"
msgid "Maximum streaming bitrate"
msgstr "Maximálny dátový tok streamovania"

msgctxt "#30635"
msgid "Any value other than unlimited disables direct play. If a stream is below the limit it will remux and if above it will transcode."
msgstr "Akákoľvek hodnota okrem „neobmedzené“ vypne priame prehrávanie. Ak je stream pod limitom, bude remuxovaný, a ak nad ním, bude prekódovaný."

